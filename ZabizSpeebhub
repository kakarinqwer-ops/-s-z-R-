-- ช่องใส่ความเร็ว
SpeedInput.Name = "SpeedInput"
SpeedInput.Parent = MainFrame
SpeedInput.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
SpeedInput.Position = UDim2.new(0.1, 0, 0.5, 0)
SpeedInput.Size = UDim2.new(0.8, 0, 0, 22)
SpeedInput.Font = Enum.Font.Gotham
SpeedInput.PlaceholderText = "Set Speed"
SpeedInput.PlaceholderColor3 = Color3.fromRGB(80, 80, 80)
SpeedInput.Text = ""
SpeedInput.TextColor3 = Color3.fromRGB(255, 255, 255)
SpeedInput.TextSize = 12

local InputCorner = Instance.new("UICorner")
InputCorner.CornerRadius = UDim.new(0, 5)
InputCorner.Parent = SpeedInput

-- ระบบการทำงาน
SpeedInput.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local val = tonumber(SpeedInput.Text)
        local char = game.Players.LocalPlayer.Character
        if val and char and char:FindFirstChild("Humanoid") then
            char.Humanoid.WalkSpeed = val
        end
        SpeedInput.Text = "" -- เคลียร์ช่องหลังกด
    end
end)

-- ปุ่มปิด/เปิด (RightControl)
game:GetService("UserInputService").InputBegan:Connect(function(input, gpe)
    if not gpe and input.KeyCode == Enum.KeyCode.RightControl then
        MainFrame.Visible = not MainFrame.Visible
    end
end)
